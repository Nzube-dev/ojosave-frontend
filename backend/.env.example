# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/sorobanpay?schema=public"

# ─── Soroban RPC ─────────────────────────────────────────────────────────────
# Soroban RPC endpoint to poll for contract events.
# Testnet:  https://soroban-testnet.stellar.org
# Mainnet:  https://mainnet.stellar.validationcloud.io/v1/<YOUR_KEY>
RPC_URL="https://soroban-testnet.stellar.org"

# Stellar network passphrase — must match the RPC endpoint above.
# Testnet:  Test SDF Network ; September 2015
# Mainnet:  Public Global Stellar Network ; September 2015
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ─── Contract ────────────────────────────────────────────────────────────────
# Deployed SorobanPay contract address (C…).
# Obtain this from the output of: bash deploy/deploy.sh
CONTRACT_ID="CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ─── Server ──────────────────────────────────────────────────────────────────
# Port the Express server listens on. Defaults to 3001 if not set.
PORT=3001
